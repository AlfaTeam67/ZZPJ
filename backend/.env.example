# Fin-Insight Backend - Environment Variables Example
# Copy this file to .env and set strong, unique secrets before startup

# Eureka Server
EUREKA_SERVER_PORT=8761

# Config Server
CONFIG_SERVER_PORT=8888
CONFIG_REPO_PATH=../ZZPJ-config
CONFIG_REPO_HOST_PATH=../ZZPJ-config
CONFIG_DEFAULT_LABEL=main
# Use native file-based config repo mount in docker compose (recommended for local dev)
CONFIG_SERVER_PROFILES=docker,native
CONFIG_SERVER_NATIVE_SEARCH_LOCATIONS=file:/config-repo

# Keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_VERSION=24.0
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_STRONG_KEYCLOAK_DB_PASSWORD

# Portfolio Manager
PORTFOLIO_MANAGER_PORT=8081
PORTFOLIO_DB_NAME=portfolio
PORTFOLIO_DB_USER=portfolio_user
PORTFOLIO_DB_PASSWORD=CHANGE_ME_STRONG_PORTFOLIO_DB_PASSWORD
PORTFOLIO_DB_PORT=5433

# Market Data Service
MARKET_DATA_PORT=8082
MARKET_DATA_DB_NAME=marketdata
MARKET_DATA_DB_USER=market_data_user
MARKET_DATA_DB_PASSWORD=CHANGE_ME_STRONG_MARKET_DATA_DB_PASSWORD
MARKET_DATA_DB_PORT=5434

# AI Advisor Service
AI_ADVISOR_PORT=8083
ADVISOR_DB_NAME=advisor
ADVISOR_DB_USER=advisor_user
ADVISOR_DB_PASSWORD=CHANGE_ME_STRONG_ADVISOR_DB_PASSWORD
ADVISOR_DB_PORT=5435

# PostgreSQL
POSTGRES_VERSION=16-alpine

# Keycloak PostgreSQL
KEYCLOAK_POSTGRES_PORT=5432

# Spring Profiles
SPRING_PROFILES_ACTIVE=docker

# JWT Issuer (Keycloak realm)
JWT_ISSUER_URI=http://keycloak:8080/realms/fin-insight

# Service discovery URL
EUREKA_URL=http://eureka-server:8761/eureka/

# Internal DB host/port inside docker network
PORTFOLIO_DB_HOST=portfolio-db
PORTFOLIO_DB_INTERNAL_PORT=5432
MARKET_DATA_DB_HOST=market-data-db
MARKET_DATA_DB_INTERNAL_PORT=5432
ADVISOR_DB_HOST=advisor-db
ADVISOR_DB_INTERNAL_PORT=5432
